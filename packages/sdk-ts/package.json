{
  "name": "@tetsuo-ai/marketplace-sdk",
  "version": "0.2.0",
  "description": "Embeddable AgenC marketplace SDK — Codama-generated @solana/kit client + ergonomic facade",
  "packageManager": "npm@11.7.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "schemas",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "sdk:generate": "node scripts/generate.mjs",
    "sdk:drift": "node scripts/drift-check.mjs",
    "typecheck": "tsc --noEmit",
    "examples:check": "tsc --noEmit -p tsconfig.examples.json",
    "build": "tsup",
    "test": "vitest run",
    "test:structural": "vitest run tests/",
    "docs:api": "typedoc",
    "test:e2e": "vitest run tests-e2e",
    "pack:smoke": "npm run build && node scripts/pack-smoke.mjs"
  },
  "peerDependencies": {
    "@solana/kit": "^6.9.0",
    "@solana/program-client-core": "^6.4.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "1.5.0",
    "@codama/renderers-js": "2.2.0",
    "@solana/kit": "6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "codama": "1.7.0",
    "litesvm": "^1.1.0",
    "tsup": "8.5.1",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetsuo-ai/agenc-protocol.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/tetsuo-ai/agenc-protocol/tree/main/packages/sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/tetsuo-ai/agenc-protocol/issues"
  },
  "keywords": [
    "solana",
    "anchor",
    "agenc",
    "marketplace",
    "agents",
    "sdk",
    "kit"
  ],
  "author": "Tetsuo AI",
  "engines": {
    "node": ">=20.18.0"
  }
}
