{
  "name": "@tetsuo-ai/marketplace-sdk",
  "version": "0.12.0",
  "description": "Embeddable AgenC marketplace SDK — Codama-generated @solana/kit client + ergonomic facade",
  "packageManager": "npm@11.18.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    },
    "./sandbox": {
      "import": {
        "types": "./dist/sandbox/index.d.ts",
        "default": "./dist/sandbox/index.js"
      },
      "require": {
        "types": "./dist/sandbox/index.d.cts",
        "default": "./dist/sandbox/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "schemas",
    "testing-assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "sdk:generate": "node scripts/generate.mjs",
    "sdk:drift": "node scripts/drift-check.mjs",
    "typecheck": "tsc --noEmit",
    "examples:check": "tsc --noEmit -p tsconfig.examples.json",
    "build": "tsup",
    "pretest": "node --test scripts/sync-testing-so.test.mjs && node scripts/sync-testing-so.mjs",
    "test": "vitest run",
    "test:structural": "vitest run tests/",
    "docs:api": "typedoc",
    "test:e2e": "vitest run tests-e2e",
    "testing:sync-so": "node scripts/sync-testing-so.mjs",
    "prepack": "npm run build && npm run testing:sync-so",
    "pack:smoke": "npm run build && npm run testing:sync-so && node scripts/pack-smoke.mjs"
  },
  "peerDependencies": {
    "@solana/kit": "^6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "litesvm": "1.1.0"
  },
  "peerDependenciesMeta": {
    "litesvm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "1.5.0",
    "@codama/renderers-js": "2.2.0",
    "@solana/kit": "7.0.0",
    "@solana/program-client-core": "^6.4.0",
    "codama": "1.7.0",
    "litesvm": "1.1.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetsuo-ai/agenc-protocol.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/tetsuo-ai/agenc-protocol/tree/main/packages/sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/tetsuo-ai/agenc-protocol/issues"
  },
  "keywords": [
    "solana",
    "anchor",
    "agenc",
    "marketplace",
    "agents",
    "sdk",
    "kit"
  ],
  "author": "Tetsuo AI",
  "engines": {
    "node": ">=22.23.1"
  },
  "dependencies": {
    "@solana-program/address-lookup-table": "0.11.0"
  }
}
