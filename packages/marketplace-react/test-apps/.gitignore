# Test-app dependencies + build outputs (the apps are file:-linked fixtures;
# fixture lockfiles are ignored by default, and node_modules/build dirs are local).
*/node_modules/
*/package-lock.json
# CI runs `npm ci` for checkout and Next SSR, so both locks are reproducible
# inputs. Any ad-hoc fixture lock remains a disposable local artifact.
!checkout/package-lock.json
!next-ssr/package-lock.json
*/.next/
*/dist/
*/.vite/

# Next.js generated files (regenerated on build).
next-ssr/next-env.d.ts
next-ssr/tsconfig.tsbuildinfo

# The checkout app's runtime config is written by the Playwright global-setup and
# carries a generated buyer SECRET KEY — never commit it. The committed reference
# is sandbox-config.example.json.
checkout/public/sandbox-config.json
