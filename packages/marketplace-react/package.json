{
  "name": "@tetsuo-ai/marketplace-react",
  "version": "0.4.2",
  "description": "Headless React hooks + themable components for the AgenC marketplace — provider, indexer-first read transport, and live referrer config",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/theme/agenc-tokens.css",
    "./src/theme/agenc-tokens.css",
    "./dist/components/agenc-components.css",
    "./src/components/agenc-components.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      },
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks/index.cjs"
      }
    },
    "./signers": {
      "import": {
        "types": "./dist/signers/index.d.ts",
        "default": "./dist/signers/index.js"
      },
      "require": {
        "types": "./dist/signers/index.d.cts",
        "default": "./dist/signers/index.cjs"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/components/index.d.ts",
        "default": "./dist/components/index.js"
      },
      "require": {
        "types": "./dist/components/index.d.cts",
        "default": "./dist/components/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    },
    "./theme.css": "./dist/theme/agenc-tokens.css",
    "./components.css": "./dist/components/agenc-components.css",
    "./tailwind-preset": "./dist/theme/agenc-tailwind-preset.cjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:localnet": "AGENC_REACT_LOCALNET_E2E=1 vitest run test/playwright/checkout.e2e.test.tsx",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "ladle": "ladle serve",
    "ladle:build": "ladle build"
  },
  "peerDependencies": {
    "@solana/kit": "^6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "@tetsuo-ai/marketplace-sdk": "^0.8.0 || ^0.9.0 || ^0.10.0 || ^0.11.0 || ^0.12.0",
    "react": ">=18"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@solana/kit": "6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "@solana/react": "6.9.0",
    "@testing-library/react": "^16.1.0",
    "@tetsuo-ai/marketplace-sdk": "file:../sdk-ts",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "axe-core": "^4.12.0",
    "jsdom": "^25.0.1",
    "postcss": "8.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "3.4.19",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8",
    "vitest-axe": "^0.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetsuo-ai/agenc-protocol.git",
    "directory": "packages/marketplace-react"
  },
  "homepage": "https://github.com/tetsuo-ai/agenc-protocol/tree/main/packages/marketplace-react#readme",
  "bugs": {
    "url": "https://github.com/tetsuo-ai/agenc-protocol/issues"
  },
  "keywords": [
    "solana",
    "agenc",
    "marketplace",
    "react",
    "hooks",
    "headless",
    "embeddable"
  ],
  "author": "Tetsuo AI",
  "engines": {
    "node": ">=22.23.1"
  }
}
