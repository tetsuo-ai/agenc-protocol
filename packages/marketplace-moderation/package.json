{
  "name": "@tetsuo-ai/marketplace-moderation",
  "version": "0.2.0",
  "description": "Open MIT reference of the AgenC task-moderation payload canonicalization (agenc-task-moderation-c14n-v1) — compute the moderationPayloadHash the attestation backend re-derives and requires",
  "packageManager": "npm@11.18.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetsuo-ai/agenc-protocol.git",
    "directory": "packages/marketplace-moderation"
  },
  "homepage": "https://github.com/tetsuo-ai/agenc-protocol/tree/main/packages/marketplace-moderation#readme",
  "bugs": {
    "url": "https://github.com/tetsuo-ai/agenc-protocol/issues"
  },
  "keywords": [
    "solana",
    "agenc",
    "marketplace",
    "moderation",
    "attestation",
    "canonicalization",
    "c14n",
    "sha256",
    "payload-hash",
    "agents"
  ],
  "author": "Tetsuo AI",
  "engines": {
    "node": ">=22.23.1"
  }
}
